# gm mainnet validator config (netuid 28).
#
# These values are the same for every validator and none are secret — copy this
# file to `.env`, set BITTENSOR_HOTKEY_SEED to YOUR registered hotkey, and run.
# (`.env` is gitignored, so your seed never lands in git.)

# --- gm subnet ---
BITTENSOR_NETUID=28
# Uid that absorbs the burn slot + floor-rounding dust = the netuid-28 subnet
# owner (UID 3). Not 0 (which on netuid 28 is an unrelated zero-stake hotkey).
SUBNET_OWNER_UID=3

# --- finalized artifacts: public-read OVH bucket, NO credentials required ---
S3_BUCKET=gm-mainnet
S3_ENDPOINT_URL=https://s3.gra.io.cloud.ovh.net
AWS_REGION=gra
# Public bucket → unsigned reads; no AWS_ACCESS_KEY_ID/SECRET needed.
GM_VALIDATOR_S3_ANONYMOUS=1

# --- chain ---
BITTENSOR_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443

# --- the ONLY value you must provide: your validator hotkey ---
# A BIP-39 mnemonic ("word word ...") or a 0x-prefixed hex seed. The signing
# keypair is built in memory; no wallet keyfile is read or written to disk.
BITTENSOR_HOTKEY_SEED=

# --- optional ---
# Expose Prometheus metrics (last-submission gauges) on host:port:
# GM_VALIDATOR_METRICS_BIND=0.0.0.0:9092
